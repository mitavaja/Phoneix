# 🌐 SERVER
PORT=5000

# 🗄️ DATABASE
MONGO_URI=mongodb://127.0.0.1:27017/phreight_commerce

# 🔐 JWT AUTH
JWT_SECRET=phreight_secret_key
JWT_EXPIRE=999d

# 📦 ARAMEX API
ARAMEX_USERNAME=your_aramex_username
ARAMEX_PASSWORD=your_aramex_password
ARAMEX_ACCOUNT_NUMBER=your_account_number
ARAMEX_ACCOUNT_PIN=your_account_pin
ARAMEX_ENTITY=DEL
ARAMEX_COUNTRY_CODE=IN

# 💳 RAZORPAY
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# 📧 EMAIL (OPTIONAL)
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=support@phreight.com

# 📱 SMS / WHATSAPP (OPTIONAL)
SMS_API_KEY=your_sms_api_key

# 🗺️ GOOGLE MAPS (OPTIONAL)
GOOGLE_MAPS_API_KEY=your_google_maps_key